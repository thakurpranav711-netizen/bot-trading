# ═══════════════════════════════════════════════════════════════
# Trading Bot Configuration v2.1
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
#
# New Features:
#   • 60% minimum probability threshold for trades
#   • ₹1500 daily loss limit with automatic halt
#   • Hourly market analysis notifications
#   • Trade entry/exit notifications with full details
#   • Automatic next-day resume after daily limit
# ═══════════════════════════════════════════════════════════════

# ─── Trading Mode & Exchange ─────────────────────────────────────
# TRADING_MODE: PAPER (simulated) or LIVE (real money)
# EXCHANGE: AUTO, BINANCE, or ALPACA
TRADING_MODE=PAPER
EXCHANGE=AUTO

# ─── Trading Parameters ──────────────────────────────────────────
# TRADING_COINS: Comma-separated list of trading pairs
# ANALYSIS_INTERVAL: Seconds between trading cycles (min: 10)
TRADING_COINS=BTC/USDT,ETH/USDT,BNB/USDT
ANALYSIS_INTERVAL=300

# ═══════════════════════════════════════════════════════════════
# NEW: PROBABILITY-BASED TRADING
# ═══════════════════════════════════════════════════════════════
# Bot will ONLY enter trades when probability >= this threshold
# Recommended: 60-70% for balanced risk/opportunity

MIN_TRADE_PROBABILITY=60.0

# ═══════════════════════════════════════════════════════════════
# NEW: DAILY LOSS LIMIT (INR)
# ═══════════════════════════════════════════════════════════════
# Bot will STOP trading if daily loss reaches this limit
# All positions will be closed automatically
# Trading resumes next day at 00:00 UTC

DAILY_LOSS_LIMIT_ENABLED=true
DAILY_LOSS_LIMIT_INR=1500.0
USD_TO_INR_RATE=83.0

# ═══════════════════════════════════════════════════════════════
# NEW: HOURLY MARKET ANALYSIS
# ═══════════════════════════════════════════════════════════════
# Send market analysis notifications even when not trading
# Includes: trend, RSI, volatility, potential opportunities

HOURLY_ANALYSIS_ENABLED=true
HOURLY_ANALYSIS_INTERVAL=3600

# ─── Risk Management ─────────────────────────────────────────────
# BASE_RISK: Percentage of balance to risk per trade (0.01 = 1%)
# MAX_DAILY_DRAWDOWN: Stop trading after this % loss in a day
# EMERGENCY_DRAWDOWN: Kill switch threshold (close all positions)

BASE_RISK=0.02
MIN_RISK=0.005
MAX_RISK=0.03
MAX_DAILY_DRAWDOWN=0.05
EMERGENCY_DRAWDOWN=0.15
MAX_EXPOSURE_PCT=0.30
MAX_CONSECUTIVE_LOSSES=3

# ─── Stop Loss & Take Profit ─────────────────────────────────────
# DEFAULT_STOP_LOSS_PCT: Default stop loss percentage (0.02 = 2%)
# DEFAULT_TAKE_PROFIT_PCT: Default take profit percentage (0.03 = 3%)
# TRAILING_STOP: Enable trailing stop to lock in profits

DEFAULT_STOP_LOSS_PCT=0.02
DEFAULT_TAKE_PROFIT_PCT=0.03
TRAILING_STOP_ENABLED=true
TRAILING_STOP_PCT=0.015

# ─── Fees & Slippage ─────────────────────────────────────────────
# Typical Binance fees: 0.1% = 0.001
# Adjust slippage based on market liquidity

FEE_PCT=0.001
SLIPPAGE_PCT=0.0005

# ─── Strategy Parameters ─────────────────────────────────────────
# RISK_REWARD_RATIO: Minimum R:R for trades (1.5 = 1.5:1)
# ATR_MULTIPLIER: For dynamic stop loss calculation
# MIN_CONFIDENCE: Minimum signal confidence (now uses MIN_TRADE_PROBABILITY)

RISK_REWARD_RATIO=1.5
ATR_MULTIPLIER=1.2
MIN_CONFIDENCE=0.60
MIN_VOLATILITY_PCT=0.002
MAX_VOLATILITY_PCT=0.02

# ─── Trade Limits ───────────────────────────────────────────────
# Prevent overtrading with these limits

MAX_TRADES_PER_DAY=10
MAX_TRADES_PER_HOUR=3
MIN_TRADE_INTERVAL=60
MAX_OPEN_POSITIONS=3

# ─── Scheduler ──────────────────────────────────────────────────
# MAX_SCHED_ERRORS: Emergency stop after N consecutive errors
# MARKET_AWARE: Skip cycles when market is closed (for stocks)
# JITTER_SECONDS: Random ± delay to avoid patterns
# ADAPTIVE_INTERVAL: Auto-adjust interval based on volatility

MAX_SCHED_ERRORS=5
MARKET_AWARE=false
JITTER_SECONDS=5.0
ADAPTIVE_INTERVAL=false

# ─── Initial Balance (Paper Trading) ─────────────────────────────
# Starting balance for paper trading simulation

INITIAL_BALANCE=100.0

# ─── Debug ──────────────────────────────────────────────────────
# Enable verbose logging for troubleshooting

DEBUG_MODE=false

# ═══════════════════════════════════════════════════════════════
# TELEGRAM NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════
# Get your bot token from @BotFather
# Get your chat ID from @userinfobot or @getidsbot

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_RETRY_COUNT=3

# ─── Notification Types ──────────────────────────────────────────
# Control which notifications you receive

TRADE_NOTIFICATIONS=true
ANALYSIS_NOTIFICATIONS=true
ERROR_NOTIFICATIONS=true
DAILY_SUMMARY_ENABLED=true

# ═══════════════════════════════════════════════════════════════
# EXCHANGE API KEYS
# ═══════════════════════════════════════════════════════════════
# Only needed for LIVE trading mode
# Keep these SECRET - never commit to git!

# ─── Binance API ─────────────────────────────────────────────────
# Get keys from: https://www.binance.com/en/my/settings/api-management
# For testnet: https://testnet.binance.vision/

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=false

# ─── Alpaca API (for US stocks/crypto) ──────────────────────────
# Get keys from: https://app.alpaca.markets/

ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ═══════════════════════════════════════════════════════════════
# QUICK START CONFIGURATIONS
# ═══════════════════════════════════════════════════════════════
#
# CONSERVATIVE (Low Risk):
#   MIN_TRADE_PROBABILITY=70.0
#   BASE_RISK=0.01
#   DAILY_LOSS_LIMIT_INR=1000.0
#   MAX_TRADES_PER_DAY=5
#   RISK_REWARD_RATIO=2.0
#
# BALANCED (Recommended):
#   MIN_TRADE_PROBABILITY=60.0
#   BASE_RISK=0.02
#   DAILY_LOSS_LIMIT_INR=1500.0
#   MAX_TRADES_PER_DAY=10
#   RISK_REWARD_RATIO=1.5
#
# AGGRESSIVE (High Risk):
#   MIN_TRADE_PROBABILITY=55.0
#   BASE_RISK=0.03
#   DAILY_LOSS_LIMIT_INR=2500.0
#   MAX_TRADES_PER_DAY=15
#   RISK_REWARD_RATIO=1.2
#
# ═══════════════════════════════════════════════════════════════