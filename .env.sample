# ═══════════════════════════════════════════════════════════════
# Trading Bot Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values

# ─── Trading Mode & Exchange ─────────────────────────────────────
TRADING_MODE=PAPER
EXCHANGE=AUTO

# ─── Trading Parameters ──────────────────────────────────────────
TRADING_COINS=BTC/USDT,ETH/USDT
ANALYSIS_INTERVAL=300

# ─── Risk Management ─────────────────────────────────────────────
BASE_RISK=0.01
MIN_RISK=0.003
MAX_RISK=0.03
MAX_DAILY_DRAWDOWN=0.05
EMERGENCY_DRAWDOWN=0.15
MAX_EXPOSURE_PCT=0.30
MAX_CONSECUTIVE_LOSSES=3

# ─── Fees & Slippage ─────────────────────────────────────────────
FEE_PCT=0.001
SLIPPAGE_PCT=0.0005

# ─── Strategy Parameters ─────────────────────────────────────────
RISK_REWARD_RATIO=2.0
ATR_MULTIPLIER=1.2
MIN_CONFIDENCE=0.55
MIN_VOLATILITY_PCT=0.002
MAX_VOLATILITY_PCT=0.02

# ─── Trade Limits ───────────────────────────────────────────────
MAX_TRADES_PER_DAY=10
MAX_TRADES_PER_HOUR=3
MIN_TRADE_INTERVAL=60

# ─── Scheduler ──────────────────────────────────────────────────
MAX_SCHED_ERRORS=5
MARKET_AWARE=false
JITTER_SECONDS=0.0

# ─── Initial Balance (Paper Trading) ─────────────────────────────
INITIAL_BALANCE=100.0

# ─── Debug ──────────────────────────────────────────────────────
DEBUG_MODE=false

# ─── Telegram Bot ────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_RETRY_COUNT=3

# ─── Alpaca API (for US stocks/crypto) ──────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets



